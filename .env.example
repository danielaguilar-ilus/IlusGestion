# ════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO — Sistema ILUS Etiquetas
# ════════════════════════════════════════════════════════════
# Copia este archivo a .env (que está en .gitignore) y completa
# con tus credenciales reales. En Railway, define cada variable
# en el dashboard del proyecto.
#
# IMPORTANTE: si una variable NO está definida, config.py usa
# un valor de respaldo (hardcoded). En PRODUCCIÓN siempre define
# todas las variables aquí abajo y rota las credenciales viejas.
# ════════════════════════════════════════════════════════════

# ── Base de datos MySQL principal (Clever Cloud) ──
MYSQL_HOST=
MYSQL_PORT=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# ── ERP Random — MySQL directo (legacy, casi sin uso) ──
ERP_MYSQL_HOST=
ERP_MYSQL_PORT=
ERP_MYSQL_USER=
ERP_MYSQL_PASSWORD=
ERP_MYSQL_DATABASE=

# ── ERP Random — REST API (la que de verdad se usa) ──
ERP_API_URL=https://lab.random.cl/ilus
ERP_API_TOKEN=

# ── Anthropic Claude (análisis de contratos PDF) ──
ANTHROPIC_API_KEY=

# ── Cloudinary (fotos productos) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── SMTP (envío correos retiros, recuperación clave, etc.) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=ILUS Sport & Health
SMTP_FROM_ADDR=
